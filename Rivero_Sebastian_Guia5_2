#include <stdio.h>

int main() 
{
    int i, n, mayor;
    float suma = 0, promedio;
    for (i = 1; i <= 15; i++) {
        printf("Ingrese un numero: ");
        scanf("%d", &n);
        suma += n;
        if (n > mayor) mayor = n;
    }
    promedio = suma / 15;
    printf("Promedio: %.2f\n", promedio);
    printf("Mayor: %d\n", mayor);
    return 0;
}
