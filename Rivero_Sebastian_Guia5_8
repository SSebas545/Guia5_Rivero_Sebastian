#include <stdio.h>

int main() 
{
    int i, num=0, neg=0, pos=0, ceros=0;
    for(i = 1; i <= 10; i++) {
        printf("Ingrese el numero %d: ", i);
        scanf("%d", &num);
        if (num < 0) {
            neg++;
        } else if (num > 0) {
            pos++;
        } else {
            ceros++;
        }
    }
    printf("Numeros negativos: %d\n", neg);
    printf("Numeros positivos: %d\n", pos);
    printf("Ceros: %d\n", ceros);
    return 0;
}