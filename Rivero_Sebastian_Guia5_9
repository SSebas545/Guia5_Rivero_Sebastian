#include <stdio.h>

int main() 
{
    int i, sueldo, mas = 0, menos = 0;

    for (i = 1; i <= 20; i++) {
        printf("Ingrese el sueldo de la persona %d: ", i);
        scanf("%d", &sueldo);

        if (sueldo > 2000) {
            mas++;
        } else {
            menos++;
        }
    }

    printf("Personas que ganan más de $2000: %d\n", mas);
    printf("Personas que ganan menos de $2000: %d\n", menos);

    return 0;
}